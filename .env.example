# App
MONITOR_APP_NAME="infra-health-monitor"
MONITOR_DEBUG=false

# Logging — level (DEBUG/INFO/WARNING/ERROR) and format ("text" or "json").
# docker-compose sets json; use text for local development.
MONITOR_LOG_LEVEL="INFO"
MONITOR_LOG_FORMAT="text"

# Tracing (OpenTelemetry) — opt-in, requires `pip install '.[otel]'`.
MONITOR_OTEL_ENABLED=false
MONITOR_OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
MONITOR_OTEL_SERVICE_NAME="infra-health-monitor"

# Database (SQLAlchemy URL). Defaults to local SQLite.
MONITOR_DATABASE_URL="sqlite:///./monitor.db"
# Example Postgres: postgresql+psycopg://user:pass@localhost:5432/monitor

# Redis (for alert deduplication)
MONITOR_REDIS_URL="redis://localhost:6379/0"

# Path to the services config file
MONITOR_SERVICES_FILE="services.yaml"

# Default timeouts (seconds)
MONITOR_DEFAULT_TIMEOUT=5.0

# System check thresholds (percent)
MONITOR_CPU_THRESHOLD=90.0
MONITOR_MEMORY_THRESHOLD=90.0
MONITOR_DISK_THRESHOLD=90.0

# Consecutive unhealthy checks before alerting (anti-flapping)
MONITOR_FAILURE_THRESHOLD=3

# Days of check history to keep in the database (0 = forever)
MONITOR_RETENTION_DAYS=30

# High availability — run multiple replicas safely (requires Redis). When true,
# replicas elect one leader via a Redis lock; only the leader runs checks.
MONITOR_HA_ENABLED=false
MONITOR_LEADER_TTL=30

# Alert providers — leave empty to disable
MONITOR_DISCORD_WEBHOOK_URL=""
MONITOR_TELEGRAM_BOT_TOKEN=""
MONITOR_TELEGRAM_CHAT_ID=""

# API auth — all empty = open access (quick-start default).
# Set api_key for automation (header X-API-Key) and/or basic_auth_* for the
# browser dashboard. /health, /ready and /metrics stay open regardless.
MONITOR_API_KEY=""
MONITOR_BASIC_AUTH_USER=""
MONITOR_BASIC_AUTH_PASSWORD=""

# Per-IP rate limiting — on by default (basic abuse protection). Exempts
# /health, /ready and /metrics so orchestrators/Prometheus are never throttled.
MONITOR_RATE_LIMIT_ENABLED=true
MONITOR_RATE_LIMIT_PER_WINDOW=100
MONITOR_RATE_LIMIT_WINDOW_SECONDS=60

# ── docker-compose secrets (override all of these for anything public) ──
# Postgres credentials — also assembled into MONITOR_DATABASE_URL by compose.
POSTGRES_USER="monitor"
POSTGRES_PASSWORD="monitor"
POSTGRES_DB="monitor"
# Redis password — compose starts Redis with --requirepass and builds the URL.
REDIS_PASSWORD="monitor"
# Grafana admin password.
GRAFANA_ADMIN_PASSWORD="admin"
