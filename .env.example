# App
MONITOR_APP_NAME="infra-health-monitor"
MONITOR_DEBUG=false

# Database (SQLAlchemy URL). Defaults to local SQLite.
MONITOR_DATABASE_URL="sqlite:///./monitor.db"
# Example Postgres: postgresql+psycopg://user:pass@localhost:5432/monitor

# Redis (for alert deduplication)
MONITOR_REDIS_URL="redis://localhost:6379/0"

# Path to the services config file
MONITOR_SERVICES_FILE="services.yaml"

# Default timeouts (seconds)
MONITOR_DEFAULT_TIMEOUT=5.0

# System check thresholds (percent)
MONITOR_CPU_THRESHOLD=90.0
MONITOR_MEMORY_THRESHOLD=90.0
MONITOR_DISK_THRESHOLD=90.0

# Alert providers — leave empty to disable
MONITOR_DISCORD_WEBHOOK_URL=""
MONITOR_TELEGRAM_BOT_TOKEN=""
MONITOR_TELEGRAM_CHAT_ID=""
